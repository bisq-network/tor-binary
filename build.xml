<?xml version="1.0"?>
<project name="tor-binaries" default="checkSignatures">

    <property name="project.source.directory" value="tmp"/>
    <property name="torbrowser.version" value="15.0.13"/>
    <property name="torbrowser.download.base.url" value="https://archive.torproject.org/tor-package-archive/torbrowser/${torbrowser.version}"/>
    <target name="checkSignatures">

        <delete dir="${project.source.directory}" failonerror="false"/>
        <mkdir dir="${project.source.directory}"/>
        <parallel>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-windows-i686-${torbrowser.version}.tar.gz"
                dest="${project.source.directory}/tor-expert-bundle-windows-i686-${torbrowser.version}.tar.gz"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-windows-i686-${torbrowser.version}.tar.gz.asc"
                dest="${project.source.directory}/tor-expert-bundle-windows-i686-${torbrowser.version}.tar.gz.asc"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-windows-x86_64-${torbrowser.version}.tar.gz"
                dest="${project.source.directory}/tor-expert-bundle-windows-x86_64-${torbrowser.version}.tar.gz"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-windows-x86_64-${torbrowser.version}.tar.gz.asc"
                dest="${project.source.directory}/tor-expert-bundle-windows-x86_64-${torbrowser.version}.tar.gz.asc"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-macos-x86_64-${torbrowser.version}.tar.gz"
                dest="${project.source.directory}/tor-expert-bundle-macos-x86_64-${torbrowser.version}.tar.gz"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-macos-x86_64-${torbrowser.version}.tar.gz.asc"
                dest="${project.source.directory}/tor-expert-bundle-macos-x86_64-${torbrowser.version}.tar.gz.asc"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-macos-aarch64-${torbrowser.version}.tar.gz"
                dest="${project.source.directory}/tor-expert-bundle-macos-aarch64-${torbrowser.version}.tar.gz"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-macos-aarch64-${torbrowser.version}.tar.gz.asc"
                dest="${project.source.directory}/tor-expert-bundle-macos-aarch64-${torbrowser.version}.tar.gz.asc"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-linux-i686-${torbrowser.version}.tar.gz"
                dest="${project.source.directory}/tor-expert-bundle-linux-i686-${torbrowser.version}.tar.gz"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-linux-i686-${torbrowser.version}.tar.gz.asc"
                dest="${project.source.directory}/tor-expert-bundle-linux-i686-${torbrowser.version}.tar.gz.asc"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-linux-x86_64-${torbrowser.version}.tar.gz"
                dest="${project.source.directory}/tor-expert-bundle-linux-x86_64-${torbrowser.version}.tar.gz"
                skipexisting="true"/>
            <get
                src="${torbrowser.download.base.url}/tor-expert-bundle-linux-x86_64-${torbrowser.version}.tar.gz.asc"
                dest="${project.source.directory}/tor-expert-bundle-linux-x86_64-${torbrowser.version}.tar.gz.asc"
                skipexisting="true"/>
        </parallel>
        <parallel>
            <exec executable="gpg" failonerror="true">
                <arg
                    line="--auto-key-locate keyserver --keyserver keys.openpgp.org --keyserver-options auto-key-retrieve --verify ${project.source.directory}/tor-expert-bundle-windows-i686-${torbrowser.version}.tar.gz.asc ${project.source.directory}/tor-expert-bundle-windows-i686-${torbrowser.version}.tar.gz"></arg>
            </exec>
            <exec executable="gpg" failonerror="true">
                <arg
                    line="--auto-key-locate keyserver --keyserver keys.openpgp.org --keyserver-options auto-key-retrieve --verify ${project.source.directory}/tor-expert-bundle-windows-x86_64-${torbrowser.version}.tar.gz.asc ${project.source.directory}/tor-expert-bundle-windows-x86_64-${torbrowser.version}.tar.gz"></arg>
            </exec>
            <exec executable="gpg" failonerror="true">
                <arg
                    line="--auto-key-locate keyserver --keyserver keys.openpgp.org --keyserver-options auto-key-retrieve --verify ${project.source.directory}/tor-expert-bundle-macos-x86_64-${torbrowser.version}.tar.gz.asc ${project.source.directory}/tor-expert-bundle-macos-x86_64-${torbrowser.version}.tar.gz"></arg>
            </exec>
            <exec executable="gpg" failonerror="true">
                <arg
                    line="--auto-key-locate keyserver --keyserver keys.openpgp.org --keyserver-options auto-key-retrieve --verify ${project.source.directory}/tor-expert-bundle-macos-aarch64-${torbrowser.version}.tar.gz.asc ${project.source.directory}/tor-expert-bundle-macos-aarch64-${torbrowser.version}.tar.gz"></arg>
            </exec>
            <exec executable="gpg" failonerror="true">
                <arg
                    line="--auto-key-locate keyserver --keyserver keys.openpgp.org --keyserver-options auto-key-retrieve --verify ${project.source.directory}/tor-expert-bundle-linux-i686-${torbrowser.version}.tar.gz.asc ${project.source.directory}/tor-expert-bundle-linux-i686-${torbrowser.version}.tar.gz"></arg>
            </exec>
            <exec executable="gpg" failonerror="true">
                <arg
                    line="--auto-key-locate keyserver --keyserver keys.openpgp.org --keyserver-options auto-key-retrieve --verify ${project.source.directory}/tor-expert-bundle-linux-x86_64-${torbrowser.version}.tar.gz.asc ${project.source.directory}/tor-expert-bundle-linux-x86_64-${torbrowser.version}.tar.gz"></arg>
            </exec>
        </parallel>

        <checksum algorithm="SHA-256" todir="tor-binary-resources/checksums">
            <fileset dir="${project.source.directory}">
                <exclude name="*.asc"/>
            </fileset>
        </checksum>

        <delete dir="${project.source.directory}"/>
    </target>
</project>
